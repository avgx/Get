# Скопируй в `.env` в корне репозитория (файл `.env` в git не коммитится).
# Переменные в окружении процесса перекрывают значения из `.env`.

GET_TEST_LAN=1
GET_TEST_HOST=192.168.1.41
GET_TEST_USER=root
GET_TEST_PASSWORD=

GET_TEST_SSE_PATH=
# Для ``MultipartFrameStream`` нужен ответ с multipart (например boundary=ngpboundary).
GET_TEST_MJPEG_PATH=
# WebSocket по ws:// (тот же хост и Basic auth, что и для HTTP).
GET_TEST_WS_PATH=
# 1 = запустить 10‑минутный интеграционный прослушивающий тест WS (см. lanWebSocketLongListenPayloadBytesAndState).
GET_TEST_WS_LONG_LISTEN=
