# WebSocket path on ws:// (same host and Basic auth as HTTP).
GET_TEST_WS_PATH=
# 1 = run the 10-minute WS listen integration test (see lanWebSocketLongListenPayloadBytesAndState).
GET_TEST_WS_LONG_LISTEN=
