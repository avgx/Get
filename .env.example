# Copy to `.env` in the repo root (`.env` is not committed).
# Process environment variables override values from `.env`.

GET_TEST_LAN=1
GET_TEST_HOST=192.168.1.41
GET_TEST_USER=root
GET_TEST_PASSWORD=

GET_TEST_SSE_PATH=
